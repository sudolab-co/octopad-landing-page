---
// Pillar 3 — Memory
// Animated SVG chat transcript: user asks Claude to review a competitor,
// Claude calls web_search (native AI tool — magnifying-glass icon), then
// the Octopad knowledge.create tool (mascot). Three typed artifacts
// cascade in — each row is `label:` (italic, outside) + a paper chip
// holding the content. The chip treatment matches Pillar 2's task-card
// grammar: when Octopad saves something, it looks like paper.
//
// Cycle: 12s. Format parity with PillarContextChat.astro (cream surface,
// pill user message, tool-call `name: argument` with split tspans,
// left-aligned reply, no typewriter).
---

<div class="pillar-chat memory" role="img" aria-label="Claude conversation: Alex asks Claude to review Acme Corp, a competitor name that keeps coming up. Claude calls its native web_search tool for 'Acme Corp review', then calls the Octopad knowledge.create tool and files three typed artifacts: a page titled Acme Corp — competitor review, a key fact that Acme Corp is now a top named competitor, and a risk that Acme Corp's traction may crowd our mindshare. Claude replies that it reviewed Acme Corp and logged new information.">
  <svg viewBox="0 0 520 312" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">

    <defs>
      <!-- Soft drop shadow for the chat surface (matches Pillars 1 & 2) -->
      <filter id="frame-shadow-3" x="-4%" y="-4%" width="108%" height="110%">
        <feDropShadow dx="0" dy="4" stdDeviation="10" flood-color="#1a1410" flood-opacity="0.06"/>
      </filter>
    </defs>

    <!-- Cream chat surface -->
    <rect class="frame" x="4" y="4" width="512" height="304" rx="16" filter="url(#frame-shadow-3)"/>

    <!-- 1 · User message — rounded pill, right-aligned -->
    <g class="step user-step">
      <rect class="user-bubble" x="80" y="22" width="412" height="36" rx="18"/>
      <text class="user-msg" x="478" y="46" text-anchor="end" font-size="15">can you review Acme Corp? I keep hearing their name</text>
    </g>

    <!-- 2 · Native AI tool: web_search. Magnifying-glass icon — NOT the
         Octopad mascot (this is the AI's own built-in capability). -->
    <g class="step search-step-3">
      <g class="search-icon" transform="translate(28, 72)">
        <circle cx="11" cy="11" r="6" fill="none" stroke="currentColor" stroke-width="1.6"/>
        <line x1="15.2" y1="15.2" x2="20" y2="20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </g>
      <text class="tool-line" x="62" y="90" font-size="13.5">
        <tspan class="tl-name">web_search</tspan><tspan class="tl-sep">: </tspan><tspan class="tl-arg">Acme Corp review</tspan>
      </text>
    </g>

    <!-- 3 · Octopad tool: knowledge.create. Mascot icon signals the
         brand entering the transcript. -->
    <g class="step capture-step-3">
      <image class="action-mascot" href="/assets/mascot.png" x="28" y="116" width="26" height="24"/>
      <text class="tool-line" x="62" y="134" font-size="13.5">
        <tspan class="tl-name">knowledge.create</tspan>
      </text>
    </g>

    <!-- 4 · Page capture — italic label + paper chip holding the title -->
    <g class="step item-page-3">
      <text class="k-label" x="28" y="172" font-size="13">page:</text>
      <rect class="k-chip" x="86" y="158" width="222" height="20" rx="5"/>
      <text class="k-content" x="95" y="172" font-size="13">Acme Corp — competitor review</text>
    </g>

    <!-- 5 · Key-fact capture -->
    <g class="step item-keyfact-3">
      <text class="k-label" x="28" y="206" font-size="13">key fact:</text>
      <rect class="k-chip" x="86" y="192" width="274" height="20" rx="5"/>
      <text class="k-content" x="95" y="206" font-size="13">Acme Corp is now a top named competitor</text>
    </g>

    <!-- 6 · Risk capture (severity label removed — three rows now share one
         uniform chip, type carried by the label word alone) -->
    <g class="step item-risk-3">
      <text class="k-label" x="28" y="240" font-size="13">risk:</text>
      <rect class="k-chip" x="86" y="226" width="306" height="20" rx="5"/>
      <text class="k-content" x="95" y="240" font-size="13">Acme Corp&#8217;s traction may crowd our mindshare</text>
    </g>

    <!-- 7 · Assistant reply — left-aligned prose, no bubble, no cursor -->
    <g class="step reply-step">
      <text class="reply-msg" x="28" y="288" font-size="15">I&#8217;ve reviewed Acme Corp and logged new information</text>
    </g>
  </svg>
</div>

<style>
  .pillar-chat { width: 100%; display: flex; justify-content: center; }
  .pillar-chat svg { display: block; width: 100%; max-width: 560px; height: auto; }

  /* Claude-style warm cream chat surface */
  .frame {
    fill: #F9F9F6;
    stroke: #EDECE4;
    stroke-width: 1;
  }

  /* User message bubble — subtle darker tone (matches Pillars 1 & 2) */
  .user-bubble { fill: #EEEFEC; }
  .user-msg {
    font-family: var(--font);
    font-weight: 400;
    fill: var(--ink);
    letter-spacing: -0.005em;
  }

  /* Tool call line: mono name + mono separator + italic argument */
  .tool-line { white-space: pre; }
  .tl-name {
    font-family: var(--mono);
    font-weight: 500;
    fill: var(--ink);
  }
  .tl-sep {
    font-family: var(--mono);
    fill: var(--ink-mute);
  }
  .tl-arg {
    font-family: var(--font);
    font-style: italic;
    fill: var(--ink-soft);
  }

  /* Search (native) icon — dark ink, upright glyph */
  .search-icon { color: var(--ink); }

  /* Capture rows: italic label outside, paper chip around the content.
     Chip surface + border match Pillar 2's task cards — system-wide
     grammar that "things Octopad saves look like paper". */
  .k-label {
    font-family: var(--font);
    font-style: italic;
    fill: var(--ink-mute);
  }
  .k-chip {
    fill: #FFFDF7;
    stroke: #E8E6DD;
    stroke-width: 1;
  }
  .k-content {
    font-family: var(--font);
    font-weight: 400;
    fill: var(--ink);
    letter-spacing: -0.005em;
  }

  /* Assistant reply — prose, no bubble */
  .reply-msg {
    font-family: var(--font);
    font-weight: 400;
    fill: var(--ink);
    letter-spacing: -0.005em;
  }

  /* ---- Animation timeline ----
     Master cycle = 12s. Each step fades + rises into place, holds, the
     whole transcript clears at the end and loops. No typewriter. */

  .step { opacity: 0; }

  .pillar-chat.animate .user-step      { animation: in-user-3    12s ease-out infinite; }
  .pillar-chat.animate .search-step-3  { animation: in-search-3  12s ease-out infinite; }
  .pillar-chat.animate .capture-step-3 { animation: in-capture-3 12s ease-out infinite; }
  .pillar-chat.animate .item-page-3    { animation: in-page-3    12s ease-out infinite; }
  .pillar-chat.animate .item-keyfact-3 { animation: in-keyfact-3 12s ease-out infinite; }
  .pillar-chat.animate .item-risk-3    { animation: in-risk-3    12s ease-out infinite; }
  .pillar-chat.animate .reply-step     { animation: in-reply-3   12s ease-out infinite; }

  @keyframes in-user-3    { 0%       { opacity:0; transform: translateY(6px); }
                            5%, 92%  { opacity:1; transform: translateY(0); }
                            96%,100% { opacity:0; } }
  @keyframes in-search-3  { 0%, 14%  { opacity:0; transform: translateY(6px); }
                            18%, 92% { opacity:1; transform: translateY(0); }
                            96%,100% { opacity:0; } }
  @keyframes in-capture-3 { 0%, 23%  { opacity:0; transform: translateY(6px); }
                            27%, 92% { opacity:1; transform: translateY(0); }
                            96%,100% { opacity:0; } }
  @keyframes in-page-3    { 0%, 32%  { opacity:0; transform: translateY(6px); }
                            36%, 92% { opacity:1; transform: translateY(0); }
                            96%,100% { opacity:0; } }
  @keyframes in-keyfact-3 { 0%, 40%  { opacity:0; transform: translateY(6px); }
                            44%, 92% { opacity:1; transform: translateY(0); }
                            96%,100% { opacity:0; } }
  @keyframes in-risk-3    { 0%, 48%  { opacity:0; transform: translateY(6px); }
                            52%, 92% { opacity:1; transform: translateY(0); }
                            96%,100% { opacity:0; } }
  @keyframes in-reply-3   { 0%, 60%  { opacity:0; transform: translateY(6px); }
                            65%, 92% { opacity:1; transform: translateY(0); }
                            96%,100% { opacity:0; } }

  /* Reduced-motion: show the full transcript, no loop */
  @media (prefers-reduced-motion: reduce) {
    .pillar-chat .step { opacity: 1 !important; transform: none !important; }
    .pillar-chat *     { animation: none !important; }
  }
</style>

<script>
  // Trigger the looping animation when the pillar scrolls into view,
  // pause when it scrolls away so the cycle stays aligned.
  const sync = () => {
    document.querySelectorAll('.pillar-chat').forEach((el) => {
      const r = el.getBoundingClientRect();
      const inView = r.top < window.innerHeight * 0.9 && r.bottom > 0;
      el.classList.toggle('animate', inView);
    });
  };

  sync();
  window.addEventListener('scroll', sync, { passive: true });
  window.addEventListener('resize', sync, { passive: true });

  if (typeof IntersectionObserver !== 'undefined') {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => e.target.classList.toggle('animate', e.isIntersecting));
    }, { threshold: 0.15 });
    document.querySelectorAll('.pillar-chat').forEach((el) => obs.observe(el));
  }
</script>
