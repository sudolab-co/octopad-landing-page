---
interface Props {
  eyebrow?: string;
  heading: string;
  description: string;
  paddingBottom?: string;
}

const { eyebrow, heading, description, paddingBottom = '80px' } = Astro.props;
---

<section class="section" style={`padding-bottom: ${paddingBottom};`}>
  <div class="wrap">
    <div class="cta-band">
      <div>
        {eyebrow && (
          <span
            class="eyebrow"
            style="color: rgba(255,255,255,0.55); margin-bottom: 18px;"
          >
            {eyebrow}
          </span>
        )}
        <h2>{heading}</h2>
        <p>{description}</p>
      </div>
      <div class="ctas">
        <slot />
      </div>
    </div>
  </div>
</section>
