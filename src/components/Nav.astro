---
interface Props {
  page?: 'product' | 'pricing' | 'quickstart' | 'about' | 'blog';
}

const { page } = Astro.props;

const links = [
  { id: 'product', label: 'Product', href: '/' },
  { id: 'pricing', label: 'Pricing', href: '/pricing' },
  { id: 'quickstart', label: 'Quick Start', href: '/getting-started' },
  { id: 'blog', label: 'Blog', href: '/blog' },
] as const;
---

<header class="site-header">
  <div class="wrap bar">
    <a href="/" class="brand">
      <img src="/assets/mascot.png" alt="" />
      <span>Octopad</span>
    </a>
    <nav class="nav" aria-label="Primary">
      {links.map((link) => (
        <a
          href={link.href}
          aria-current={link.id === page ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="actions">
      <a href="https://www.octopad.app" class="signin">Sign in</a>
      <a href="https://www.octopad.app/signup" class="btn btn-primary">Get started</a>
    </div>
  </div>
</header>
