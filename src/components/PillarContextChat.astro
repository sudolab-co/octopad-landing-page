---
// Pillar 1 — Context
// Animated SVG mimicking a real Claude conversation: warm cream chat
// surface, user message in a rounded pill, assistant tool-call and
// streaming status items, final reply. No typewriter — items fade/rise
// into place so the whole transcript loops cleanly.
---

<div class="pillar-chat" role="img" aria-label="Claude conversation: Alex asks Claude to resume working on the home page copy. Claude calls build_context for the homepage copy task, reads the Product Overview and Brand Guidelines pages, fetches Monday's positioning decision, and replies that it created a page with homepage copy V1.">
  <svg viewBox="0 0 520 312" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">

    <defs>
      <!-- Soft drop shadow for the chat surface -->
      <filter id="frame-shadow" x="-4%" y="-4%" width="108%" height="110%">
        <feDropShadow dx="0" dy="4" stdDeviation="10" flood-color="#1a1410" flood-opacity="0.06"/>
      </filter>

      <!-- Page icon: document with folded corner -->
      <symbol id="ic-page" viewBox="0 0 14 14">
        <path d="M2.5 1.5 H8.5 L11.5 4.5 V12 a1 1 0 0 1 -1 1 H3.5 a1 1 0 0 1 -1 -1 V2.5 a1 1 0 0 1 1 -1 z"
              fill="none" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/>
        <path d="M8.5 1.5 V4.5 H11.5" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/>
      </symbol>

      <!-- Decision icon: clean check -->
      <symbol id="ic-check" viewBox="0 0 14 14">
        <polyline points="2.5,7.5 5.8,10.5 11.5,3.8"
                  fill="none" stroke="currentColor" stroke-width="1.7"
                  stroke-linecap="round" stroke-linejoin="round"/>
      </symbol>
    </defs>

    <!-- Claude-style warm cream chat surface -->
    <rect class="frame" x="4" y="4" width="512" height="304" rx="16" filter="url(#frame-shadow)"/>

    <!-- 1 · User message — rounded pill, right-aligned -->
    <g class="step user-step">
      <rect class="user-bubble" x="196" y="26" width="296" height="38" rx="19"/>
      <text class="user-msg" x="478" y="51" text-anchor="end">resume working on home page copy</text>
    </g>

    <!-- 2 · Assistant tool call: build_context: homepage copy task -->
    <g class="step ctx-step">
      <image class="action-mascot" href="/assets/mascot.png" x="28" y="92" width="26" height="24"/>
      <text x="62" y="110" class="tool-line">
        <tspan class="tl-name">build_context</tspan><tspan class="tl-sep">: </tspan><tspan class="tl-arg">homepage copy task</tspan>
      </text>
    </g>

    <!-- 3 · Streaming status items — indented under the tool call -->
    <g class="step item-page-1">
      <use href="#ic-page" x="62" y="138" width="12" height="12" class="ic ic-mute"/>
      <text class="status" x="82" y="148">reading Product Overview page</text>
    </g>
    <g class="step item-page-2">
      <use href="#ic-page" x="62" y="162" width="12" height="12" class="ic ic-mute"/>
      <text class="status" x="82" y="172">reading Brand Guidelines page</text>
    </g>
    <g class="step item-decision">
      <use href="#ic-check" x="62" y="186" width="12" height="12" class="ic ic-green"/>
      <text class="status" x="82" y="196">fetching Monday's positioning decision</text>
    </g>

    <!-- 4 · Assistant reply — left-aligned prose, no bubble -->
    <g class="step reply-step">
      <text class="reply-msg" x="28" y="252">Homepage copy V1 is ready for review</text>
    </g>
  </svg>
</div>

<style>
  .pillar-chat { width: 100%; }
  .pillar-chat svg { display: block; width: 100%; height: auto; }

  /* Claude-style cream chat surface */
  .frame {
    fill: #F7F4EC;
    stroke: #EDE7D6;
    stroke-width: 1;
  }

  /* User message bubble — slightly darker cream pill, like Claude's UI */
  .user-bubble {
    fill: #ECE7D6;
  }
  .user-msg {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 400;
    fill: var(--ink);
    letter-spacing: -0.005em;
  }

  /* Tool call line: mono name + italic argument on same baseline */
  .tool-line { white-space: pre; }
  .tl-name {
    font-family: var(--mono);
    font-size: 13.5px;
    font-weight: 500;
    fill: var(--ink);
  }
  .tl-sep {
    font-family: var(--mono);
    font-size: 13.5px;
    fill: var(--ink-mute);
  }
  .tl-arg {
    font-family: var(--font);
    font-size: 13.5px;
    font-style: italic;
    fill: var(--ink-soft);
  }

  /* Streaming status items */
  .status {
    font-family: var(--font);
    font-size: 13px;
    font-style: italic;
    fill: var(--ink-soft);
  }
  .ic-mute  { color: var(--ink-mute); opacity: 0.75; }
  .ic-green { color: var(--green); }

  /* Assistant reply — prose, not a bubble */
  .reply-msg {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 400;
    fill: var(--ink);
    letter-spacing: -0.005em;
  }

  /* ---- Animation timeline ----
     Master cycle = 11s. Each step fades + rises into place, holds, then
     the whole transcript clears at the end and loops. No typewriter. */

  .step { opacity: 0; }

  .pillar-chat.animate .user-step     { animation: in-user   11s ease-out infinite; }
  .pillar-chat.animate .ctx-step      { animation: in-ctx    11s ease-out infinite; }
  .pillar-chat.animate .item-page-1   { animation: in-p1     11s ease-out infinite; }
  .pillar-chat.animate .item-page-2   { animation: in-p2     11s ease-out infinite; }
  .pillar-chat.animate .item-decision { animation: in-dec    11s ease-out infinite; }
  .pillar-chat.animate .reply-step    { animation: in-reply  11s ease-out infinite; }

  @keyframes in-user  { 0%        { opacity: 0; transform: translateY(6px); }
                        6%, 92%   { opacity: 1; transform: translateY(0); }
                        96%, 100% { opacity: 0; } }

  @keyframes in-ctx   { 0%, 18%   { opacity: 0; transform: translateY(6px); }
                        22%, 92%  { opacity: 1; transform: translateY(0); }
                        96%, 100% { opacity: 0; } }

  @keyframes in-p1    { 0%, 28%   { opacity: 0; transform: translateY(6px); }
                        32%, 92%  { opacity: 1; transform: translateY(0); }
                        96%, 100% { opacity: 0; } }

  @keyframes in-p2    { 0%, 36%   { opacity: 0; transform: translateY(6px); }
                        40%, 92%  { opacity: 1; transform: translateY(0); }
                        96%, 100% { opacity: 0; } }

  @keyframes in-dec   { 0%, 44%   { opacity: 0; transform: translateY(6px); }
                        48%, 92%  { opacity: 1; transform: translateY(0); }
                        96%, 100% { opacity: 0; } }

  @keyframes in-reply { 0%, 58%   { opacity: 0; transform: translateY(6px); }
                        64%, 92%  { opacity: 1; transform: translateY(0); }
                        96%, 100% { opacity: 0; } }

  /* Reduced-motion: show the full transcript, no loop */
  @media (prefers-reduced-motion: reduce) {
    .pillar-chat .step { opacity: 1 !important; transform: none !important; }
    .pillar-chat *     { animation: none !important; }
  }
</style>

<script>
  // Trigger the looping animation when the pillar scrolls into view,
  // pause when it scrolls away so the cycle stays aligned.
  const sync = () => {
    document.querySelectorAll('.pillar-chat').forEach((el) => {
      const r = el.getBoundingClientRect();
      const inView = r.top < window.innerHeight * 0.9 && r.bottom > 0;
      el.classList.toggle('animate', inView);
    });
  };

  sync();
  window.addEventListener('scroll', sync, { passive: true });
  window.addEventListener('resize', sync, { passive: true });

  if (typeof IntersectionObserver !== 'undefined') {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => e.target.classList.toggle('animate', e.isIntersecting));
    }, { threshold: 0.15 });
    document.querySelectorAll('.pillar-chat').forEach((el) => obs.observe(el));
  }
</script>
