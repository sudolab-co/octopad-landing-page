---
// Pillar 1 — Context
// Animated SVG that reads as a real AI chat transcript inside a quiet
// chat-window frame. Each line appears in sequence (user types →
// AI calls build_context → "reading…" status lines stream in →
// AI begins drafting Section 1 with a typewriter cursor).
//
// The whole transcript loops on a 12s cycle so a visitor scrolling
// to the section will catch a full pass even if they arrive mid-cycle.
---

<div class="pillar-chat" role="img" aria-label="AI chat transcript: Alex asks Claude to work on the homepage copy. Claude calls build_context on Octopad, reads the Product Overview page, the Brand Guidelines page, and fetches Monday's positioning decision, then begins drafting Section 1.">
  <svg viewBox="0 0 520 440" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">

    <defs>
      <!-- Soft drop shadow for the chat-window frame -->
      <filter id="frame-shadow" x="-4%" y="-4%" width="108%" height="110%">
        <feDropShadow dx="0" dy="3" stdDeviation="8" flood-color="#0a1830" flood-opacity="0.06"/>
      </filter>

      <!-- Typewriter clip for the user message (right-aligned, reveals L→R) -->
      <clipPath id="cp-user">
        <rect class="cp-user-rect" x="208" y="40" width="0" height="36"/>
      </clipPath>

      <!-- Typewriter clip for the AI draft line -->
      <clipPath id="cp-draft">
        <rect class="cp-draft-rect" x="32" y="282" width="0" height="32"/>
      </clipPath>
    </defs>

    <!-- Chat-window frame -->
    <rect class="frame" x="4" y="4" width="512" height="432" rx="14" filter="url(#frame-shadow)"/>

    <!-- Tiny live-dot in the top-right corner of the frame -->
    <circle class="frame-dot" cx="494" cy="20" r="3"/>

    <!-- 1 · User message — typed on the right -->
    <text class="user-msg" x="488" y="64" text-anchor="end" clip-path="url(#cp-user)">Work on the homepage copy.</text>

    <!-- 2 · AI tool call: build_context -->
    <g class="step action-step">
      <image class="action-mascot" href="/assets/mascot.png" x="32" y="99" width="24" height="22"/>
      <text class="action-name" x="64" y="117">build_context</text>
    </g>

    <!-- 3 · Status lines (indented under build_context) -->
    <g class="step status-1">
      <circle class="dot" cx="68" cy="148" r="2.4"/>
      <text class="status" x="80" y="152">reading Product Overview page</text>
    </g>
    <g class="step status-2">
      <circle class="dot" cx="68" cy="176" r="2.4"/>
      <text class="status" x="80" y="180">reading Brand Guidelines page</text>
    </g>
    <g class="step status-3">
      <circle class="dot" cx="68" cy="204" r="2.4"/>
      <text class="status" x="80" y="208">fetching Monday's positioning decision</text>
    </g>

    <!-- 4 · AI reply -->
    <g class="step reply-step">
      <text class="reply-intro" x="32" y="262">Here's a draft for Section 1 —</text>
    </g>

    <!-- 5 · Draft headline + tracking cursor -->
    <text class="reply-draft" x="32" y="304" clip-path="url(#cp-draft)">The right context for every task.</text>
    <rect class="cursor" x="32" y="288" width="2.5" height="18"/>
  </svg>
</div>

<style>
  .pillar-chat { width: 100%; }
  .pillar-chat svg { display: block; width: 100%; height: auto; }

  /* Frame — the "chat window" containment Alex asked for */
  .frame {
    fill: var(--paper-raised);
    stroke: var(--line);
    stroke-width: 1;
  }
  .frame-dot {
    fill: var(--green);
    opacity: 0.55;
  }

  /* Typography */
  .user-msg {
    font-family: var(--font);
    font-size: 15px;
    fill: var(--ink);
  }
  .action-name {
    font-family: var(--mono);
    font-size: 13.5px;
    font-weight: 500;
    fill: var(--ink);
  }
  .status {
    font-family: var(--font);
    font-size: 13px;
    font-style: italic;
    fill: var(--ink-mute);
  }
  .dot {
    fill: var(--green);
  }
  .reply-intro {
    font-family: var(--font);
    font-size: 13.5px;
    fill: var(--ink-mute);
  }
  .reply-draft {
    font-family: var(--font);
    font-size: 17px;
    font-weight: 500;
    fill: var(--ink);
    letter-spacing: -0.01em;
  }
  .cursor {
    fill: var(--green);
  }

  /* ---- Animation timeline ---- */
  /* Master cycle = 12s, looping. Elements stay hidden until activated. */

  .step,
  .cursor { opacity: 0; }

  /* User message: typewriter via clipPath rect width */
  .pillar-chat.animate .cp-user-rect {
    animation: type-user 12s linear infinite;
  }
  @keyframes type-user {
    0%, 3%   { width: 0; }
    13%      { width: 280px; }
    91%      { width: 280px; }
    96%, 100%{ width: 0; }
  }

  /* AI tool call appears */
  .pillar-chat.animate .action-step {
    animation: step-life 12s ease-out infinite;
    animation-delay: 0s;
    --start: 16%;
    --in: 19%;
  }
  /* Status lines cascade in */
  .pillar-chat.animate .status-1 { animation: step-life-1 12s ease-out infinite; }
  .pillar-chat.animate .status-2 { animation: step-life-2 12s ease-out infinite; }
  .pillar-chat.animate .status-3 { animation: step-life-3 12s ease-out infinite; }
  /* Reply intro */
  .pillar-chat.animate .reply-step { animation: step-life-r 12s ease-out infinite; }

  @keyframes step-life {
    0%, 16%  { opacity: 0; transform: translateY(4px); }
    20%      { opacity: 1; transform: translateY(0); }
    91%      { opacity: 1; transform: translateY(0); }
    96%, 100%{ opacity: 0; transform: translateY(0); }
  }
  @keyframes step-life-1 {
    0%, 24%  { opacity: 0; transform: translateY(4px); }
    28%      { opacity: 1; transform: translateY(0); }
    91%      { opacity: 1; transform: translateY(0); }
    96%, 100%{ opacity: 0; transform: translateY(0); }
  }
  @keyframes step-life-2 {
    0%, 30%  { opacity: 0; transform: translateY(4px); }
    34%      { opacity: 1; transform: translateY(0); }
    91%      { opacity: 1; transform: translateY(0); }
    96%, 100%{ opacity: 0; transform: translateY(0); }
  }
  @keyframes step-life-3 {
    0%, 36%  { opacity: 0; transform: translateY(4px); }
    40%      { opacity: 1; transform: translateY(0); }
    91%      { opacity: 1; transform: translateY(0); }
    96%, 100%{ opacity: 0; transform: translateY(0); }
  }
  @keyframes step-life-r {
    0%, 47%  { opacity: 0; transform: translateY(4px); }
    50%      { opacity: 1; transform: translateY(0); }
    91%      { opacity: 1; transform: translateY(0); }
    96%, 100%{ opacity: 0; transform: translateY(0); }
  }

  /* Draft line: typewriter clip width */
  .pillar-chat.animate .cp-draft-rect {
    animation: type-draft 12s linear infinite;
  }
  @keyframes type-draft {
    0%, 53%  { width: 0; }
    66%      { width: 320px; }
    91%      { width: 320px; }
    96%, 100%{ width: 0; }
  }

  /* Cursor: tracks the typewriter position, then blinks until cycle resets */
  .pillar-chat.animate .cursor {
    animation:
      cursor-pos 12s linear infinite,
      cursor-blink 12s step-end infinite;
  }
  @keyframes cursor-pos {
    0%, 53%  { transform: translateX(0); }
    66%, 100%{ transform: translateX(285px); }
  }
  @keyframes cursor-blink {
    0%, 52%  { opacity: 0; }
    53%      { opacity: 1; }
    66%      { opacity: 1; }
    70%      { opacity: 0; }
    74%      { opacity: 1; }
    78%      { opacity: 0; }
    82%      { opacity: 1; }
    86%      { opacity: 0; }
    90%      { opacity: 1; }
    91%, 100%{ opacity: 0; }
  }

  /* Frame dot — quiet pulse so the window reads as "live" */
  .pillar-chat.animate .frame-dot {
    animation: dot-pulse 2.4s ease-in-out infinite;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 0.35; }
    50%      { opacity: 0.85; }
  }

  /* Reduced-motion: show the full transcript, skip the loop */
  @media (prefers-reduced-motion: reduce) {
    .pillar-chat .step,
    .pillar-chat .cursor { opacity: 1 !important; }
    .pillar-chat .cp-user-rect  { width: 280px !important; }
    .pillar-chat .cp-draft-rect { width: 320px !important; }
    .pillar-chat .cursor        { transform: translateX(285px) !important; }
    .pillar-chat *              { animation: none !important; }
  }
</style>

<script>
  // Trigger the looping animation as soon as the pillar is anywhere
  // close to the viewport, and re-trigger when it scrolls back in.
  // Uses a scroll listener as a reliable cross-browser baseline plus
  // an IntersectionObserver where it fires (skipped by some headless
  // / embedded browsers).
  const sync = () => {
    document.querySelectorAll('.pillar-chat').forEach((el) => {
      const r = el.getBoundingClientRect();
      const inView = r.top < window.innerHeight * 0.9 && r.bottom > 0;
      el.classList.toggle('animate', inView);
    });
  };

  sync();
  window.addEventListener('scroll', sync, { passive: true });
  window.addEventListener('resize', sync, { passive: true });

  if (typeof IntersectionObserver !== 'undefined') {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => e.target.classList.toggle('animate', e.isIntersecting));
    }, { threshold: 0.15 });
    document.querySelectorAll('.pillar-chat').forEach((el) => obs.observe(el));
  }
</script>
