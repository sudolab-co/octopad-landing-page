---
// Pillar 2 — Plans
// Animated SVG chat: user asks for a task, AI calls tasks.create,
// a real task card materializes — title + description in the body,
// status / priority / stream / assignee chips in a soft green
// footer strip. The four metadata chips are things the user did
// NOT say: the visible proof the AI is pulling structure from
// the workspace, not echoing the prompt.
// 14s cycle, same frame and trigger as PillarContextChat.
---

<div class="pillar-chat" role="img" aria-label="AI chat transcript: Alex asks Claude to add a task to tighten onboarding copy. Claude calls the Octopad tasks.create tool. A task card materializes with the title 'Tighten onboarding copy', a one-line description, and four metadata chips — Status: To-do, Priority: High, Stream: Website Launch, Assignee: Alex. Claude then replies that the task was created and assigned to the Website Launch stream.">
  <svg viewBox="0 0 520 304" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">

    <defs>
      <!-- Soft drop shadow for the chat-window frame -->
      <filter id="frame-shadow-2" x="-4%" y="-4%" width="108%" height="110%">
        <feDropShadow dx="0" dy="3" stdDeviation="8" flood-color="#0a1830" flood-opacity="0.06"/>
      </filter>

      <!-- Typewriter clip for the user message (right-aligned, reveals L→R) -->
      <clipPath id="cp-user-2">
        <rect class="cp-user-rect-2" x="140" y="28" width="0" height="32"/>
      </clipPath>

      <!-- Typewriter clip for the AI final reply -->
      <clipPath id="cp-reply-2">
        <rect class="cp-reply-rect-2" x="32" y="258" width="0" height="30"/>
      </clipPath>
    </defs>

    <!-- Chat-window frame -->
    <rect class="frame" x="4" y="4" width="512" height="296" rx="14" filter="url(#frame-shadow-2)"/>

    <!-- Tiny live-dot in the top-right corner of the frame -->
    <circle class="frame-dot" cx="494" cy="20" r="3"/>

    <!-- 1 · User message — typed on the right -->
    <text class="user-msg" x="488" y="44" text-anchor="end" clip-path="url(#cp-user-2)" font-size="15">add a task to tighten onboarding copy</text>

    <!-- 2 · AI tool call: tasks.create -->
    <g class="step tool-step">
      <image class="action-mascot" href="/assets/mascot.png" x="32" y="74" width="24" height="22"/>
      <text class="action-name" x="64" y="92" font-size="13.5">tasks.create</text>
    </g>

    <!-- 3 · Card body + footer strip + title -->
    <g class="step task-card">
      <!-- Outer card: paper inset with hairline border, rounded corners -->
      <rect class="card-bg" x="32" y="108" width="460" height="128" rx="8"/>
      <!-- Footer strip: subtle green tint, sharp top, rounded bottom -->
      <path class="card-footer" d="M 32 192 L 492 192 L 492 228 A 8 8 0 0 1 484 236 L 40 236 A 8 8 0 0 1 32 228 Z"/>
      <!-- Title -->
      <text class="card-title" x="52" y="134" font-size="15.5">Tighten onboarding copy</text>
    </g>

    <!-- 4 · Description -->
    <g class="step task-desc">
      <text class="card-desc" x="52" y="158" font-size="13">Cut setup friction in the first-run flow.</text>
    </g>

    <!-- 5 · Status chip: open ring + To-do -->
    <g class="step task-status">
      <circle class="chip-ring" cx="58" cy="215" r="4.5"/>
      <text class="chip-text" x="70" y="219" font-size="12">To-do</text>
    </g>

    <!-- 6 · Priority chip: small upward triangle + High -->
    <g class="step task-priority">
      <polygon class="chip-priority" points="148,220 156,220 152,213"/>
      <text class="chip-text" x="162" y="219" font-size="12">High</text>
    </g>

    <!-- 7 · Stream chip: green hash + Website Launch -->
    <g class="step task-stream">
      <text class="chip-hash"   x="232" y="219" font-size="13">#</text>
      <text class="chip-text"   x="242" y="219" font-size="12">Website Launch</text>
    </g>

    <!-- 8 · Assignee chip: green avatar + Alex -->
    <g class="step task-assignee">
      <circle class="chip-avatar" cx="384" cy="215" r="7"/>
      <text class="chip-avatar-letter" x="384" y="218" text-anchor="middle" font-size="9">A</text>
      <text class="chip-text" x="397" y="219" font-size="12">Alex</text>
    </g>

    <!-- 9 · AI reply — types out with cursor -->
    <text class="reply-msg" x="32" y="278" clip-path="url(#cp-reply-2)" font-size="15">I created the task and assigned it to #Website Launch.</text>
    <rect class="cursor" x="32" y="262" width="2.5" height="18"/>
  </svg>
</div>

<style>
  .pillar-chat { width: 100%; display: flex; justify-content: center; }
  .pillar-chat svg { display: block; width: 100%; max-width: 560px; height: auto; }

  /* Frame — the "chat window" containment */
  .frame {
    fill: var(--paper-raised);
    stroke: var(--line);
    stroke-width: 1;
  }
  .frame-dot {
    fill: var(--green);
    opacity: 0.55;
  }

  /* Typography — identical chat voice to Pillar 1 */
  .user-msg,
  .reply-msg {
    font-family: var(--font);
    fill: var(--ink);
  }
  .action-name {
    font-family: var(--mono);
    font-weight: 500;
    fill: var(--ink);
  }
  .cursor { fill: var(--green); }

  /* Task card — quiet paper inset with a soft tinted footer that
     carries the metadata. No accent bar, no completion check; the
     state lives in the chips. */
  .card-bg {
    fill: var(--paper);
    stroke: var(--line);
    stroke-width: 1;
  }
  .card-footer {
    fill: var(--green-soft);
  }
  .card-title {
    font-family: var(--font);
    font-weight: 500;
    fill: var(--ink);
    letter-spacing: -0.005em;
  }
  .card-desc {
    font-family: var(--font);
    font-weight: 400;
    fill: var(--ink-soft);
  }

  /* Metadata chips — naked icon + text, no pill backgrounds */
  .chip-text {
    font-family: var(--font);
    font-weight: 500;
    fill: var(--ink);
  }
  .chip-ring {
    fill: none;
    stroke: var(--ink-mute);
    stroke-width: 1.4;
  }
  .chip-priority {
    fill: var(--ink);
  }
  .chip-hash {
    font-family: var(--font);
    font-weight: 600;
    fill: var(--green);
  }
  .chip-avatar { fill: var(--green); }
  .chip-avatar-letter {
    font-family: var(--font);
    font-weight: 700;
    fill: var(--paper-raised);
  }

  /* ---- Animation timeline ---- */
  /* Master cycle = 14s, looping. Elements stay hidden until activated. */

  .pillar-chat .step,
  .pillar-chat .cursor { opacity: 0; }

  /* User message typewriter */
  .pillar-chat.animate .cp-user-rect-2 {
    animation: type-user-2 14s linear infinite;
  }
  @keyframes type-user-2 {
    0%, 2%   { width: 0; }
    11%      { width: 360px; }
    92%      { width: 360px; }
    96%, 100%{ width: 0; }
  }

  /* Sequenced reveals — tool, then card frame+title, then description,
     then four metadata chips cascade in */
  .pillar-chat.animate .tool-step     { animation: in-tool-2   14s ease-out infinite; }
  .pillar-chat.animate .task-card     { animation: in-card-2   14s ease-out infinite; }
  .pillar-chat.animate .task-desc     { animation: in-desc-2   14s ease-out infinite; }
  .pillar-chat.animate .task-status   { animation: in-st-2     14s ease-out infinite; }
  .pillar-chat.animate .task-priority { animation: in-prio-2   14s ease-out infinite; }
  .pillar-chat.animate .task-stream   { animation: in-stream-2 14s ease-out infinite; }
  .pillar-chat.animate .task-assignee { animation: in-assign-2 14s ease-out infinite; }

  @keyframes in-tool-2   { 0%,14% {opacity:0;transform:translateY(4px)} 18%,92% {opacity:1;transform:translateY(0)} 96%,100% {opacity:0} }
  @keyframes in-card-2   { 0%,22% {opacity:0;transform:translateY(6px)} 27%,92% {opacity:1;transform:translateY(0)} 96%,100% {opacity:0} }
  @keyframes in-desc-2   { 0%,29% {opacity:0;transform:translateY(4px)} 33%,92% {opacity:1;transform:translateY(0)} 96%,100% {opacity:0} }
  @keyframes in-st-2     { 0%,37% {opacity:0;transform:translateY(4px)} 40%,92% {opacity:1;transform:translateY(0)} 96%,100% {opacity:0} }
  @keyframes in-prio-2   { 0%,42% {opacity:0;transform:translateY(4px)} 45%,92% {opacity:1;transform:translateY(0)} 96%,100% {opacity:0} }
  @keyframes in-stream-2 { 0%,47% {opacity:0;transform:translateY(4px)} 50%,92% {opacity:1;transform:translateY(0)} 96%,100% {opacity:0} }
  @keyframes in-assign-2 { 0%,52% {opacity:0;transform:translateY(4px)} 55%,92% {opacity:1;transform:translateY(0)} 96%,100% {opacity:0} }

  /* Reply typewriter */
  .pillar-chat.animate .cp-reply-rect-2 {
    animation: type-reply-2 14s linear infinite;
  }
  @keyframes type-reply-2 {
    0%, 60%  { width: 0; }
    74%      { width: 445px; }
    92%      { width: 445px; }
    96%, 100%{ width: 0; }
  }

  /* Cursor tracks reply then blinks */
  .pillar-chat.animate .cursor {
    animation:
      cursor-pos-2 14s linear infinite,
      cursor-blink-2 14s step-end infinite;
  }
  @keyframes cursor-pos-2 {
    0%, 60%  { transform: translateX(0); }
    74%, 100%{ transform: translateX(400px); }
  }
  @keyframes cursor-blink-2 {
    0%, 59%  { opacity: 0; }
    60%      { opacity: 1; }
    74%      { opacity: 1; }
    78%      { opacity: 0; }
    82%      { opacity: 1; }
    86%      { opacity: 0; }
    90%      { opacity: 1; }
    92%      { opacity: 1; }
    93%, 100%{ opacity: 0; }
  }

  /* Frame live-dot quiet pulse */
  .pillar-chat.animate .frame-dot {
    animation: dot-pulse-2 2.4s ease-in-out infinite;
  }
  @keyframes dot-pulse-2 {
    0%, 100% { opacity: 0.35; }
    50%      { opacity: 0.85; }
  }

  /* Reduced-motion: show the full transcript, skip the loop */
  @media (prefers-reduced-motion: reduce) {
    .pillar-chat .step,
    .pillar-chat .cursor { opacity: 1 !important; }
    .pillar-chat .cp-user-rect-2  { width: 360px !important; }
    .pillar-chat .cp-reply-rect-2 { width: 445px !important; }
    .pillar-chat .cursor          { transform: translateX(400px) !important; }
    .pillar-chat *                { animation: none !important; }
  }
</style>

<script>
  // Same IntersectionObserver pattern as Pillar 1 — idempotent class toggle.
  const sync = () => {
    document.querySelectorAll('.pillar-chat').forEach((el) => {
      const r = el.getBoundingClientRect();
      const inView = r.top < window.innerHeight * 0.9 && r.bottom > 0;
      el.classList.toggle('animate', inView);
    });
  };

  sync();
  window.addEventListener('scroll', sync, { passive: true });
  window.addEventListener('resize', sync, { passive: true });

  if (typeof IntersectionObserver !== 'undefined') {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => e.target.classList.toggle('animate', e.isIntersecting));
    }, { threshold: 0.15 });
    document.querySelectorAll('.pillar-chat').forEach((el) => obs.observe(el));
  }
</script>
