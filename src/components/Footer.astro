---
const columns = [
  {
    heading: 'Product',
    links: [
      { label: 'Features', href: '/' },
      { label: 'Pricing', href: '/pricing' },
      { label: 'Quick Start', href: '/getting-started' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Blog', href: '/blog' },
      { label: 'Contact', href: 'mailto:support@octopad.ai' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Privacy', href: '/privacy' },
      { label: 'Terms', href: '/terms' },
    ],
  },
  {
    heading: 'Works with',
    links: [{ label: 'Any MCP-compatible AI model', href: '#' }],
  },
];
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a href="/" class="brand">
          <img src="/assets/mascot.png" alt="" />
          <span>Octopad</span>
        </a>
        <p class="small" style="max-width: 32ch; margin-top: 14px;">
          Your AI's back-office. One shared brain across every AI your team uses.
        </p>
      </div>
      {columns.map((col) => (
        <div>
          <h4>{col.heading}</h4>
          <ul>
            {col.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <span>© 2026 Octopad</span>
      <span>
        <a href="https://x.com/octopad_ai">@octopad_ai on X</a>
      </span>
    </div>
  </div>
</footer>
