---
// Cookie preferences and (geo-conditional) Your Privacy Choices links
// are rendered as <button> elements that the consent module wires up
// client-side. A plain <a href> would scroll-jump.
const productLinks = [
  { label: 'Features', href: '/' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Quick Start', href: '/getting-started' },
];

const companyLinks = [
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: 'mailto:support@octopad.ai' },
];

const legalLinks = [
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
  { label: 'DPA', href: '/dpa' },
];
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a href="/" class="brand">
          <img src="/assets/mascot.svg" alt="" width="24" height="24" />
          <span>Octopad</span>
        </a>
        <p class="small" style="max-width: 32ch; margin-top: 14px;">
          Your AI's back-office. The same context across every AI your team uses.
        </p>
      </div>
      <div>
        <h3>Product</h3>
        <ul>
          {productLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3>Company</h3>
        <ul>
          {companyLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3>Legal</h3>
        <ul>
          {legalLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
          <li>
            <button type="button" class="footer-link-btn" data-consent-open-modal>
              Cookie preferences
            </button>
          </li>
          <li hidden data-ccpa-link>
            <button type="button" class="footer-link-btn" data-consent-open-ccpa>
              Your Privacy Choices
            </button>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Octopad</span>
      <span>
        <a href="https://x.com/octopad_ai">@octopad_ai on X</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .footer-link-btn {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    color: inherit;
    font: inherit;
    cursor: pointer;
    text-align: start;
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 120ms;
  }
  .footer-link-btn:hover {
    text-decoration-color: currentColor;
  }
  .footer-link-btn:focus-visible {
    outline: 2px solid var(--accent, #2a9f73);
    outline-offset: 2px;
  }
</style>
