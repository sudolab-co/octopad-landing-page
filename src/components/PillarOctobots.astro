---
// Pillar 4 — Octobots
// Animated SVG showing Octopad's mascot as a processing layer. Mixed
// workspace inputs (tasks, comments, pages, files, activity events) drift
// in from the left on three lanes and converge on the mascot in the
// center. The mascot pulses gently as it "processes", and a steady flow
// of uniform paper cards emerges to the right — the structured output.
//
// The shape uniformity of the output cards is the whole message: chaos
// in, consistent artifacts out. That's the Octobot value prop rendered
// visually, one beat at a time. Cream frame and paper-chip grammar match
// P1/P2/P3; the pipeline metaphor is the conceptual break.
---

<div class="pillar-chat octobots" role="img" aria-label="Workspace data flowing through Octopad's mascot. Tasks, comments, pages, files, and activity events drift in from the left on three horizontal lanes and converge on the mascot in the center, which pulses gently as it processes them. A continuous flow of uniform paper cards — the structured output — emerges from the mascot and drifts off to the right.">
  <svg viewBox="0 0 520 312" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">

    <defs>
      <filter id="frame-shadow-4" x="-4%" y="-4%" width="108%" height="110%">
        <feDropShadow dx="0" dy="4" stdDeviation="10" flood-color="#1a1410" flood-opacity="0.06"/>
      </filter>

      <!-- Input glyphs: all ~14x14, single-weight strokes in ink-mute.
           Represent the varied raw artifacts a workspace generates. -->
      <symbol id="ic-task" viewBox="0 0 14 14">
        <rect x="2" y="2" width="10" height="10" rx="2.2" fill="none"
              stroke="currentColor" stroke-width="1.1"/>
        <polyline points="4.7,7.1 6.4,8.8 9.4,5.4" fill="none"
                  stroke="currentColor" stroke-width="1.3"
                  stroke-linecap="round" stroke-linejoin="round"/>
      </symbol>

      <symbol id="ic-comment" viewBox="0 0 14 14">
        <path d="M2 4.2 a1.8 1.8 0 0 1 1.8 -1.8 H10.2 a1.8 1.8 0 0 1 1.8 1.8 V9 a1.8 1.8 0 0 1 -1.8 1.8 H6 L4 12.6 V10.8 a1.8 1.8 0 0 1 -2 -1.8 Z"
              fill="none" stroke="currentColor" stroke-width="1.1"
              stroke-linejoin="round"/>
      </symbol>

      <symbol id="ic-page-4" viewBox="0 0 14 14">
        <path d="M2.5 1.5 H8.5 L11.5 4.5 V12 a1 1 0 0 1 -1 1 H3.5 a1 1 0 0 1 -1 -1 V2.5 a1 1 0 0 1 1 -1 z"
              fill="none" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/>
        <path d="M8.5 1.5 V4.5 H11.5"
              fill="none" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/>
      </symbol>

      <symbol id="ic-file" viewBox="0 0 14 14">
        <path d="M10.8 6.4 L6 11.2 a2.5 2.5 0 0 1 -3.6 -3.6 L7.4 2.6 a1.55 1.55 0 0 1 2.2 2.2 L5 9.4"
              fill="none" stroke="currentColor" stroke-width="1.1"
              stroke-linecap="round" stroke-linejoin="round"/>
      </symbol>

      <symbol id="ic-activity" viewBox="0 0 14 14">
        <circle cx="7" cy="7" r="4.8" fill="none" stroke="currentColor"
                stroke-width="1" opacity="0.45"/>
        <circle cx="7" cy="7" r="2" fill="currentColor"/>
      </symbol>
    </defs>

    <!-- Same cream chat surface as P1/P2/P3 -->
    <rect class="frame" x="4" y="4" width="512" height="304" rx="16" filter="url(#frame-shadow-4)"/>

    <!-- ---- Input flow ----
         Nine inputs cycle through three lanes. Each lane ships three
         glyphs, each icon staggered across the 6s master cycle by
         negative animation-delay, so the page loads mid-flow. Icon type
         per slot is hand-picked to mix task/comment/page/file/activity
         across the lanes without perfect 1-to-1 lane mapping. -->

    <g class="input lane-1" style="animation-delay: 0s">       <use href="#ic-task" width="17" height="17"/></g>
    <g class="input lane-1" style="animation-delay: -2s">      <use href="#ic-page-4" width="17" height="17"/></g>
    <g class="input lane-1" style="animation-delay: -4s">      <use href="#ic-comment" width="17" height="17"/></g>

    <g class="input lane-2" style="animation-delay: -0.7s">    <use href="#ic-file" width="17" height="17"/></g>
    <g class="input lane-2" style="animation-delay: -2.7s">    <use href="#ic-activity" width="17" height="17"/></g>
    <g class="input lane-2" style="animation-delay: -4.7s">    <use href="#ic-task" width="17" height="17"/></g>

    <g class="input lane-3" style="animation-delay: -1.4s">    <use href="#ic-comment" width="17" height="17"/></g>
    <g class="input lane-3" style="animation-delay: -3.4s">    <use href="#ic-page-4" width="17" height="17"/></g>
    <g class="input lane-3" style="animation-delay: -5.4s">    <use href="#ic-activity" width="17" height="17"/></g>

    <!-- ---- Output flow ----
         Output cards are drawn BEFORE the mascot in SVG source so the
         mascot's opaque body occludes the portion of each card that's
         still inside it. Combined with a delayed opacity fade-in, this
         makes each card look like it's emerging from the mascot's right
         edge. All cards identical in shape: title bar + two content
         lines + a trailing dot. Uniformity IS the "structured" message. -->

    <g class="out-card" style="animation-delay: 0s">
      <rect class="card-bg" width="74" height="31" rx="5"/>
      <rect class="card-title" x="8" y="7" width="31" height="3" rx="1.4"/>
      <line class="card-line" x1="8" y1="17.4" x2="59" y2="17.4"/>
      <line class="card-line" x1="8" y1="23.4" x2="48" y2="23.4"/>
      <circle class="card-dot" cx="60" cy="23.4" r="1.6"/>
    </g>
    <g class="out-card" style="animation-delay: -1.5s">
      <rect class="card-bg" width="74" height="31" rx="5"/>
      <rect class="card-title" x="8" y="7" width="31" height="3" rx="1.4"/>
      <line class="card-line" x1="8" y1="17.4" x2="59" y2="17.4"/>
      <line class="card-line" x1="8" y1="23.4" x2="48" y2="23.4"/>
      <circle class="card-dot" cx="60" cy="23.4" r="1.6"/>
    </g>
    <g class="out-card" style="animation-delay: -3s">
      <rect class="card-bg" width="74" height="31" rx="5"/>
      <rect class="card-title" x="8" y="7" width="31" height="3" rx="1.4"/>
      <line class="card-line" x1="8" y1="17.4" x2="59" y2="17.4"/>
      <line class="card-line" x1="8" y1="23.4" x2="48" y2="23.4"/>
      <circle class="card-dot" cx="60" cy="23.4" r="1.6"/>
    </g>
    <g class="out-card" style="animation-delay: -4.5s">
      <rect class="card-bg" width="74" height="31" rx="5"/>
      <rect class="card-title" x="8" y="7" width="31" height="3" rx="1.4"/>
      <line class="card-line" x1="8" y1="17.4" x2="59" y2="17.4"/>
      <line class="card-line" x1="8" y1="23.4" x2="48" y2="23.4"/>
      <circle class="card-dot" cx="60" cy="23.4" r="1.6"/>
    </g>

    <!-- ---- Mascot — the processing layer ----
         Centered; wrapper sits at (260, 156) and the image is offset so
         its center falls on (0, 0) of the wrapper. That lets the pulse
         animation scale from the image center rather than its top-left.
         Drawn LAST so it occludes any output card that's still inside
         its bounds. Image is 20% larger than the initial cut. -->
    <g class="mascot-wrap">
      <image class="mascot-img" href="/assets/mascot.svg"
             x="-55" y="-51.5" width="110" height="103"/>
    </g>
  </svg>
</div>

<style>
  .pillar-chat.octobots { width: 100%; display: flex; justify-content: center; }
  /* Same frame size as P1/P2/P3 — the 20% size bump happens inside,
     to the mascot and the flying elements, not to the frame. */
  .pillar-chat.octobots svg { display: block; width: 100%; max-width: 560px; height: auto; }

  /* Same cream frame as P1/P2/P3 */
  .pillar-chat.octobots .frame {
    fill: #F9F9F6;
    stroke: #EDECE4;
    stroke-width: 1;
  }

  /* ---- Input glyphs ---- */
  .pillar-chat.octobots .input {
    color: var(--ink-mute);
    opacity: 0;
  }

  /* ---- Output cards ---- */
  .pillar-chat.octobots .out-card { opacity: 0; }
  .pillar-chat.octobots .card-bg {
    fill: #FFFDF7;
    stroke: #E8E6DD;
    stroke-width: 1;
  }
  .pillar-chat.octobots .card-title {
    fill: var(--ink);
    opacity: 0.72;
  }
  .pillar-chat.octobots .card-line {
    stroke: var(--ink-mute);
    stroke-width: 1;
    opacity: 0.55;
  }
  .pillar-chat.octobots .card-dot {
    fill: var(--ink-mute);
    opacity: 0.7;
  }

  /* ---- Mascot ---- */
  .pillar-chat.octobots .mascot-wrap {
    /* Base position; pulse keyframe re-asserts the translate so the
       scale composes cleanly from the image center. */
    transform: translate(260px, 156px);
  }
  .pillar-chat.octobots .mascot-img { /* renders via href */ }

  /* ---- Animation timeline ----
     6s master cycle. Inputs slide left-to-right across their lane and
     fade as they reach the mascot. Outputs emerge from the mascot and
     slide right, fading as they exit the frame. Mascot breathes on its
     own 1.2s cycle. Negative animation-delays stagger instances so the
     page loads with a flow already in motion.

     Keyframe translates are absolute (include the base position) so we
     don't need to compose with a wrapper transform. */

  .pillar-chat.octobots.animate .input.lane-1  { animation: flow-l1  6s linear infinite; }
  .pillar-chat.octobots.animate .input.lane-2  { animation: flow-l2  6s linear infinite; }
  .pillar-chat.octobots.animate .input.lane-3  { animation: flow-l3  6s linear infinite; }
  .pillar-chat.octobots.animate .out-card      { animation: flow-out 6s linear infinite; }
  .pillar-chat.octobots.animate .mascot-wrap   { animation: mascot-pulse 1.2s ease-in-out infinite; }

  /* Inputs: slide in from off-frame left, travel straight along their
     lane y for the first half of the cycle, then converge diagonally
     toward the mascot center (260, 156). Lane 2 is already at y=156
     so it stays horizontal. Opacity fades as each icon enters the
     mascot's bounds and is visually absorbed. */
  @keyframes flow-l1 {
    0%   { transform: translate(-20px, 100px); opacity: 0; }
    8%   { opacity: 1; }
    50%  { transform: translate(100px, 100px); opacity: 1; }
    82%  { opacity: 1; }
    100% { transform: translate(232px, 156px); opacity: 0; }
  }
  @keyframes flow-l2 {
    0%   { transform: translate(-20px, 156px); opacity: 0; }
    8%   { opacity: 1; }
    82%  { opacity: 1; }
    100% { transform: translate(232px, 156px); opacity: 0; }
  }
  @keyframes flow-l3 {
    0%   { transform: translate(-20px, 212px); opacity: 0; }
    8%   { opacity: 1; }
    50%  { transform: translate(100px, 212px); opacity: 1; }
    82%  { opacity: 1; }
    100% { transform: translate(232px, 156px); opacity: 0; }
  }

  /* Outputs: start at (268, 141) — behind the mascot's right lobe — and
     travel to x=528 off the right edge. The mascot now spans roughly
     x=205–315 with the bumped 110-unit image, so we hold opacity at 0
     until the card has cleared the mascot's right edge (about 18%
     through the cycle), then fade in. Combined with the SVG source
     reorder (card drawn before mascot), the card only becomes visible
     once it's genuinely emerged from the mascot. Card top y=141 so the
     31-unit card centers on the mascot's y=156. */
  @keyframes flow-out {
    0%    { transform: translate(268px, 141px); opacity: 0; }
    18%   { opacity: 0; }
    26%   { opacity: 1; }
    82%   { opacity: 1; }
    100%  { transform: translate(528px, 141px); opacity: 0; }
  }

  /* Mascot breathes. The translate is re-asserted in every keyframe so
     the scale composes around the wrapper's center (the image inside is
     drawn with a negative x/y offset so its center sits at 0,0). */
  @keyframes mascot-pulse {
    0%, 100% { transform: translate(260px, 156px) scale(1); }
    50%      { transform: translate(260px, 156px) scale(1.035); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pillar-chat.octobots .input,
    .pillar-chat.octobots .out-card { opacity: 1 !important; animation: none !important; }
    .pillar-chat.octobots .mascot-wrap { animation: none !important; }
    /* Freeze a readable still: place one icon per lane partway through
       the convergence (so lanes 1 and 3 show their diagonal toward the
       mascot), outputs spread along the right half past the mascot.
       With 74-wide cards only two fit past the bigger mascot before
       the frame edge, so we show two and hide the rest. */
    .pillar-chat.octobots .input.lane-1 { transform: translate(180px, 134px); }
    .pillar-chat.octobots .input.lane-2 { transform: translate(180px, 156px); }
    .pillar-chat.octobots .input.lane-3 { transform: translate(180px, 178px); }
    .pillar-chat.octobots .out-card:nth-of-type(1) { transform: translate(320px, 141px); }
    .pillar-chat.octobots .out-card:nth-of-type(2) { transform: translate(410px, 141px); }
    .pillar-chat.octobots .out-card:nth-of-type(3) { display: none; }
    .pillar-chat.octobots .out-card:nth-of-type(4) { display: none; }
  }
</style>

<script>
  // Trigger the looping animation when the pillar scrolls into view —
  // matches the pattern used by P1/P2/P3.
  const syncOctobots = () => {
    document.querySelectorAll('.pillar-chat.octobots').forEach((el) => {
      const r = el.getBoundingClientRect();
      const inView = r.top < window.innerHeight * 0.9 && r.bottom > 0;
      el.classList.toggle('animate', inView);
    });
  };

  syncOctobots();
  window.addEventListener('scroll', syncOctobots, { passive: true });
  window.addEventListener('resize', syncOctobots, { passive: true });

  if (typeof IntersectionObserver !== 'undefined') {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => e.target.classList.toggle('animate', e.isIntersecting));
    }, { threshold: 0.15 });
    document.querySelectorAll('.pillar-chat.octobots').forEach((el) => obs.observe(el));
  }
</script>
