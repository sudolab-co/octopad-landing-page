---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHead from '../components/PageHead.astro';
import Pillar from '../components/Pillar.astro';
import CTABand from '../components/CTABand.astro';

const team = [
  { initials: 'MK', name: 'Mira Karlsson', role: 'CEO · prev. Linear' },
  { initials: 'JL', name: 'Jon Leclerc', role: 'Design · prev. Figma' },
  { initials: 'AS', name: 'Anya Shah', role: 'Engineering · prev. Stripe' },
  { initials: 'TO', name: 'Tomás Oviedo', role: 'Product · prev. Anthropic' },
  { initials: 'RN', name: 'Ren Nakamura', role: 'Infra' },
  { initials: 'EB', name: 'Elena Borges', role: 'Engineering' },
  { initials: 'DP', name: 'Devon Park', role: 'GTM' },
  { initials: 'HR', name: 'Hana Reyes', role: 'Engineering' },
];

const values = [
  {
    num: '01',
    title: 'Bring your own AI.',
    body: 'The best model changes every month. Octopad is model-agnostic on purpose — pick whichever is winning this week.',
  },
  {
    num: '02',
    title: 'Your data stays yours.',
    body: 'We never see your inference payloads. Workspaces export in one click. Self-host whenever you\'re ready.',
  },
  {
    num: '03',
    title: 'Boring beats clever.',
    body: 'AI apps should feel as calm as a well-kept notebook. If it surprises you in a bad way, we got it wrong.',
  },
];
---

<BaseLayout title="Octopad — About" page="about">
  <PageHead
    kicker="About"
    heading="We build for<br/>teams who ship."
    lede="Octopad started because every team we knew was running AI on an island — great tools, no shared memory. We're building the back-office those teams wish they had."
  />

  <section class="section">
    <div class="wrap">
      <Pillar>
        <Fragment slot="copy">
          <span class="eyebrow eyebrow-green">Our story</span>
          <h2 class="section-title">From scattered to shared.</h2>
        </Fragment>
        <div>
          <p class="copy">
            In early 2025, four of us were working on the same product from
            different timezones — and running three different AIs between us.
            Each session started from scratch. Every decision got rediscovered.
          </p>
          <p class="copy" style="margin-top: 16px;">
            We built the first version of Octopad for ourselves: a place where
            any AI could read the same notes, run the same plans, and hand off
            cleanly between sessions. By the end of the month, our team shipped
            twice as much. Friends asked for access.
          </p>
          <p class="copy" style="margin-top: 16px;">
            That's what we're building now — not another AI, but the
            connective tissue between the ones you already use.
          </p>
        </div>
      </Pillar>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <span class="eyebrow eyebrow-green">What we believe</span>
      <h2 class="section-title" style="margin-top: 14px; max-width: 14ch;">
        Three things we keep coming back to.
      </h2>
      <div class="values">
        {values.map((v) => (
          <div class="value">
            <div class="num">{v.num}</div>
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <span class="eyebrow eyebrow-green">Team</span>
      <h2 class="section-title" style="margin-top: 14px;">Small, senior, remote.</h2>
      <p class="copy" style="margin-top: 18px;">
        Eight people across four timezones. Previously Linear, Stripe, Figma, Anthropic.
      </p>
      <div class="team">
        {team.map((m) => (
          <div class="member">
            <div class="avatar">{m.initials}</div>
            <h4>{m.name}</h4>
            <p>{m.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Hiring"
    heading="Come build with us."
    description="We're hiring two engineers and a designer. Small team, real responsibility, calm pace."
  >
    <a href="#" class="btn btn-primary btn-lg">See open roles</a>
    <a href="#" class="btn btn-ghost">Read our handbook</a>
  </CTABand>
</BaseLayout>
