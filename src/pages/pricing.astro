---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHead from '../components/PageHead.astro';
import CTABand from '../components/CTABand.astro';

const freeFeatures = [
  '1 workspace',
  'Unlimited members, tasks, goals, and work streams',
  '100 pages',
  '10 file uploads, up to 5 MB each',
  '1 week of AI session memory',
  'Essential octobots',
  'Slack, Telegram, and GitHub integrations',
  'Notion import',
];

const proFeatures = [
  'Unlimited workspaces',
  'Unlimited pages and files (up to 20 MB each)',
  'Unlimited AI session memory',
  'All octobots',
  'Email support',
];
---

<BaseLayout
  title="Octopad — Pricing | Free forever, Pro from $9 per seat"
  description="Free forever for small teams. Pro from $9 per seat per month ($7 annual) with unlimited workspaces, unlimited pages, unlimited AI session memory, and all octobots. First month of Pro included."
  page="pricing"
>
  <PageHead
    kicker="Pricing"
    heading="Simple pricing."
    lede="Free forever, with one month of Pro on the house."
  />

  <section class="wrap" style="padding-bottom: 80px;">
    <div class="plans">
      <div class="plan">
        <div class="name"><h3>Free</h3></div>
        <div class="price">$0<small> forever</small></div>
        <p class="small">For a founder or small team trying Octopad with their AI.</p>
        <a href="https://www.octopad.app/signup" class="btn btn-secondary btn-lg" style="justify-content: center;">Start free</a>
        <hr class="rule" />
        <ul>
          {freeFeatures.map((f) => (
            <li>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 7.5L5.5 10.5L11.5 3.5" /></svg>
              {f}
            </li>
          ))}
        </ul>
      </div>

      <div class="plan featured">
        <div class="name">
          <h3>Pro</h3>
          <span class="badge">First month free</span>
        </div>
        <div class="price">$9<small> per seat / month</small></div>
        <p class="small-price">Or $7 per seat per month billed annually.</p>
        <p class="small">For teams running real work through their AI every day.</p>
        <a href="https://www.octopad.app/signup" class="btn btn-primary btn-lg" style="justify-content: center;">Start free</a>
        <hr class="rule" />
        <p class="plan-prelude">Everything in Free, plus:</p>
        <ul>
          {proFeatures.map((f) => (
            <li>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 7.5L5.5 10.5L11.5 3.5" /></svg>
              {f}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <CTABand
    eyebrow="Still weighing it"
    heading="Try it on a real project."
    description="The free tier is more than enough to decide. Invite two teammates and run one plan — you'll know within a day."
  >
    <a href="https://www.octopad.app/signup" class="btn btn-primary btn-lg">Start free</a>
    <a href="/getting-started" class="btn btn-ghost">Quick Start</a>
  </CTABand>
</BaseLayout>

<style>
  .small-price {
    color: var(--ink-mute);
    font-size: 14px;
    margin-top: -6px;
    margin-bottom: 10px;
  }
  .plan-prelude {
    color: var(--ink-soft);
    font-size: 14px;
    margin: 0 0 10px;
    font-weight: 500;
  }
</style>
