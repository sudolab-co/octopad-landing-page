---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHead from '../components/PageHead.astro';
---

<BaseLayout
  title="Octopad Blog | Notes from the shared brain"
  description="Dispatches from the Octopad team on AI tooling, engineering, design, and the back-office pattern. First posts arrive at launch."
  page="blog"
>
  <PageHead
    kicker="Blog · Dispatches"
    heading="Notes from <br/>the shared brain."
    lede="What we're building, what we're learning, and occasionally what we're wrong about. First posts arrive at launch."
  />

  <section class="wrap" style="padding: 40px 0 120px;">
    <div class="blog-soon">
      <span class="blog-soon-tag">Coming soon</span>
      <h2 class="blog-soon-title">We're writing our first posts right now.</h2>
      <p class="blog-soon-sub">
        The opening run of essays drops at launch. Until then, you can follow
        along on X or jump straight into the product.
      </p>
      <div class="blog-soon-ctas">
        <a href="https://www.octopad.app/signup" class="btn btn-primary btn-lg">Start free</a>
        <a href="https://x.com/octopad_ai" class="btn btn-ghost">@octopad_ai on X</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-soon {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: 48px 0;
  }
  .blog-soon-tag {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 12px; letter-spacing: 0.8px; text-transform: uppercase;
    color: var(--green); font-weight: 600;
    padding: 6px 12px;
    background: var(--green-soft);
    border-radius: 999px;
  }
  .blog-soon-title {
    margin-top: 20px;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.1; letter-spacing: -0.02em; font-weight: 500;
  }
  .blog-soon-sub {
    margin: 16px auto 0;
    max-width: 48ch;
    color: var(--ink-soft);
    font-size: 16px;
    line-height: 1.6;
  }
  .blog-soon-ctas {
    margin-top: 28px;
    display: flex; gap: 12px;
    justify-content: center; flex-wrap: wrap;
  }
</style>
