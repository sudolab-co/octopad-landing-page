---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Pillar from '../components/Pillar.astro';
import PillarContextChat from '../components/PillarContextChat.astro';
import PillarPlansChat from '../components/PillarPlansChat.astro';
import PillarMemoryChat from '../components/PillarMemoryChat.astro';
import PillarOctobots from '../components/PillarOctobots.astro';
import Card from '../components/Card.astro';
import Tile from '../components/Tile.astro';
import CTABand from '../components/CTABand.astro';
import FAQ from '../components/FAQ.astro';
import { buildFAQSchema } from '../data/faq';

const faqSchema = buildFAQSchema();
---

<BaseLayout
  title="Octopad — Your AI's back-office"
  description="A shared workspace where any AI your team uses — Claude, ChatGPT, Cursor — can make plans, run tasks, and capture what matters on one shared brain."
  page="product"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <Hero
    heading="Your AI's <br/>back-office"
    lede="Knows the context. Plans the work. Captures what matters. All in your AI."
    primaryCta={{ label: 'Start free', href: 'https://www.octopad.app/signup' }}
    trustLine="Free to start. No credit card."
  >
    <p slot="trust-row" class="hero-trust">
      <span class="brand">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1.5c.4 3.9 1.3 6.5 2.8 8s4.1 2.4 8 2.8c-3.9.4-6.5 1.3-8 2.8s-2.4 4.1-2.8 8c-.4-3.9-1.3-6.5-2.8-8s-4.1-2.4-8-2.8c3.9-.4 6.5-1.3 8-2.8s2.4-4.1 2.8-8z"/></svg>
        Claude
      </span>
      <span class="sep">·</span>
      <span class="brand">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.911 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.182a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .511 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.998-2.9 6.056 6.056 0 0 0-.748-7.073zm-9.022 12.608a4.476 4.476 0 0 1-2.876-1.041l.142-.08 4.778-2.758a.795.795 0 0 0 .393-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.495 4.494zm-9.66-4.125a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.758a.771.771 0 0 0 .78 0l5.843-3.368v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.499 4.499 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.814 3.355-2.02 1.168a.076.076 0 0 1-.071 0L3.985 13.81A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.856L13.104 8.364l2.015-1.164a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.104v-5.677a.79.79 0 0 0-.407-.667zm2.011-3.023l-.142-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.499 4.499 0 0 1 6.68 4.66zM8.307 12.863l-2.02-1.164a.08.08 0 0 1-.038-.057V6.074a4.499 4.499 0 0 1 7.376-3.454l-.142.081L8.704 5.46a.795.795 0 0 0-.393.681zm1.098-2.365l2.602-1.5 2.607 1.5v2.999l-2.598 1.5-2.607-1.5z"/></svg>
        ChatGPT
      </span>
      <span class="sep">·</span>
      <span class="brand">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" fill-opacity="0.55" d="M11.925 24l10.425-6-10.425-6L1.5 18z"/>
          <path fill="currentColor" fill-opacity="0.85" d="M22.35 18V6L11.925 0v12z"/>
          <path fill="currentColor" d="M11.925 0L1.5 6v12l10.425-6z"/>
        </svg>
        Cursor
      </span>
      <span class="mcp-more"><span class="sep">·</span> and any MCP-compatible AI</span>
    </p>
  </Hero>

  <hr class="rule" />

  <!-- Vision bridge -->
  <section class="section section-vision">
    <div class="wrap">
      <div class="vision">
        <h2 class="vision-title">In control.<br/>Not in the loop.</h2>
        <p class="vision-sub">Octopad gives your AI the context to understand the work, the plans to execute it, and the memory to carry it forward. You spend your day steering outcomes, not supervising prompts. That's the symbiosis worth building toward.</p>
      </div>
    </div>
  </section>

  <!-- Pillar 01 — Context -->
  <section class="section section-pillar">
    <div class="wrap">
      <Pillar>
        <Fragment slot="copy">
          <span class="eyebrow pillar-num">01</span>
          <h2 class="section-title">The right context for every task</h2>
          <p class="lede">Your AI knows what each task needs, without any prompt. It pulls from the information in your workspace, picks what matters, and builds the right mix for every job.</p>
        </Fragment>
        <PillarContextChat />
      </Pillar>
    </div>
  </section>

  <!-- Pillar 02 — Plans -->
  <section class="section section-pillar">
    <div class="wrap">
      <Pillar reverse>
        <Fragment slot="copy">
          <span class="eyebrow pillar-num">02</span>
          <h2 class="section-title">Plans ready for execution</h2>
          <p class="lede">Your AI generates detail-rich tasks and maintains execution coherence from start to finish. It writes every task the same way, ties it to your strategy, and keeps the work moving across sessions, on its own.</p>
        </Fragment>
        <PillarPlansChat />
      </Pillar>
    </div>
  </section>

  <!-- Pillar 03 — Memory -->
  <section class="section section-pillar">
    <div class="wrap">
      <Pillar>
        <Fragment slot="copy">
          <span class="eyebrow pillar-num">03</span>
          <h2 class="section-title">Information captured as you go</h2>
          <p class="lede">Your AI keeps your team's knowledge current as new information surfaces. It writes down what's worth keeping from every conversation, connects it to what's already there, and updates it as things change, all in your workspace.</p>
        </Fragment>
        <PillarMemoryChat />
      </Pillar>
    </div>
  </section>

  <!-- Pillar 04 — Octobots -->
  <section class="section section-pillar">
    <div class="wrap">
      <Pillar reverse>
        <Fragment slot="copy">
          <span class="eyebrow pillar-num">04</span>
          <h2 class="section-title">Agents in the background</h2>
          <p class="lede">A crew of Octobots keeps your workspace in order while you work. They recap every session, summarize every page, and log every stream's activity, so your AI always walks into a clean desk.</p>
        </Fragment>
        <PillarOctobots />
      </Pillar>
    </div>
  </section>

  <!-- Section 06 — Quick Start teaser -->
  <section class="section">
    <div class="wrap">
      <Pillar reverse>
        <Fragment slot="copy">
          <span class="eyebrow">Quick Start</span>
          <h2 class="section-title">Set up in minutes</h2>
          <p class="lede">
            Four short steps. No credit card to start.
          </p>
          <a href="/getting-started" class="quickstart-link">See the full setup guide →</a>
        </Fragment>
        <Card flush ariaHidden={false}>
          <ol class="quickstart-steps">
            <li>
              <span class="step-num">01</span>
              <div class="step-body">
                <span class="step-lead">Sign up.</span> Free, no credit card.
                <a href="https://www.octopad.app/signup" class="btn btn-primary step-cta">Start free →</a>
              </div>
            </li>
            <li>
              <span class="step-num">02</span>
              <div class="step-body">
                Follow the onboarding to connect your AI and set up your workspace.
              </div>
            </li>
            <li>
              <span class="step-num">03</span>
              <div class="step-body">
                In your AI, say <code>use octopad</code> and tell it about your company and what you are building. Your AI will capture that information and load it at each session.
              </div>
            </li>
            <li>
              <span class="step-num">04</span>
              <div class="step-body">
                Your AI's back-office is now ready for work.
              </div>
            </li>
          </ol>
        </Card>
      </Pillar>
    </div>
  </section>

  <!-- Section 07 — FAQ (accordion + FAQPage JSON-LD via head slot) -->
  <FAQ />

  <CTABand
    heading="Give your AI the back-office it's been missing"
    description="Free to start. No credit card."
    mascot
  >
    <a href="https://www.octopad.app/signup" class="btn btn-primary btn-xl">Start free</a>
    <a href="/pricing" class="ctas-sub">See pricing</a>
  </CTABand>
</BaseLayout>
