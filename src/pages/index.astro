---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Pillar from '../components/Pillar.astro';
import PillarContextChat from '../components/PillarContextChat.astro';
import Card from '../components/Card.astro';
import Tile from '../components/Tile.astro';
import CTABand from '../components/CTABand.astro';
import FAQ from '../components/FAQ.astro';
import { buildFAQSchema } from '../data/faq';

const captureRows = [
  { n: '01', t: 'Ship v0.4 Friday — plan', m: 'Agreed w/ eng · Mar 21', done: true },
  { n: '02', t: 'Pricing: keep the free tier', m: 'Decision · Mar 18', done: true },
  { n: '03', t: 'Design review — notes', m: '7 annotations on flow B', done: true },
  { n: '04', t: 'Launch email draft — running', m: 'Pulled 3 docs · brand voice', done: false },
];

const faqSchema = buildFAQSchema();
---

<BaseLayout
  title="Octopad — Your AI's back-office"
  description="A shared workspace where any AI your team uses — Claude, ChatGPT, Cursor — can make plans, run tasks, and capture what matters on one shared brain."
  page="product"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <Hero
    heading="Your AI's<br/>back-office."
    lede="Make plans, run tasks, and capture what matters, all in your AI, all on one shared brain."
    primaryCta={{ label: 'Start free', href: '#' }}
    secondaryCta={{ label: 'See how it works', href: '#' }}
    trustLine="Free plan, no card. Pro from $9 per seat when you're ready."
  />

  <hr class="rule" />

  <!-- Social proof strip -->
  <section class="wrap">
    <div class="trust">
      <span class="eyebrow label">Works with Claude, ChatGPT, Cursor, and any MCP-compatible AI.</span>
      <div class="logos">
        <b>Claude</b><span class="dot"></span>
        <b>ChatGPT</b><span class="dot"></span>
        <b>Cursor</b><span class="dot"></span>
        <span class="mcp-pill">+ any MCP-compatible AI</span>
      </div>
    </div>
  </section>

  <!-- Pillar 01 — Context -->
  <section class="section">
    <div class="wrap">
      <Pillar>
        <Fragment slot="copy">
          <span class="eyebrow eyebrow-green">Context</span>
          <h2 class="section-title">The right context for every task.</h2>
          <p class="lede">Your AI pulls the information it needs, without any prompt.</p>
          <p class="copy">
            Every job needs its specific context. Your AI reaches into your shared brain, pulls what matters, and builds the right mix before you even ask.
          </p>
        </Fragment>
        <PillarContextChat />
      </Pillar>
    </div>
  </section>

  <!-- Pillar 02 — Plans -->
  <section class="section">
    <div class="wrap">
      <Pillar reverse>
        <Fragment slot="copy">
          <span class="eyebrow eyebrow-green">Plans</span>
          <h2 class="section-title">Detailed plans ready for execution.</h2>
          <p class="lede">Your AI generates detail-rich tasks and maintains execution coherence from start to finish.</p>
          <p class="copy">
            A plan is only as strong as its execution. Your AI writes every task the same way, ties it to your strategy, and keeps the work moving across every session, on its own.
          </p>
        </Fragment>
        <Card ariaHidden>
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
            <span class="pulse"></span>
            <span class="small" style="font-weight: 500; color: var(--ink);">Plan: Ship v0.4 onboarding</span>
            <span class="small" style="margin-left: auto;">4 of 7</span>
          </div>
          <ol style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
            <li style="display: flex; gap: 12px; align-items: center; padding: 10px 12px; background: var(--green-soft); border-radius: 7px;">
              <span class="check-bullet">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 5.5L4 7.5L8.5 2.5"/></svg>
              </span>
              <span style="font-size: 14px; color: var(--ink);">Audit current onboarding drop-off</span>
              <span class="small" style="margin-left: auto;">Claude · 2m</span>
            </li>
            <li style="display: flex; gap: 12px; align-items: center; padding: 10px 12px; background: var(--green-soft); border-radius: 7px;">
              <span class="check-bullet">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 5.5L4 7.5L8.5 2.5"/></svg>
              </span>
              <span style="font-size: 14px; color: var(--ink);">Draft 3 flow variations</span>
              <span class="small" style="margin-left: auto;">Cursor · 11m</span>
            </li>
            <li style="display: flex; gap: 12px; align-items: center; padding: 10px 12px; border: 1px dashed var(--line); border-radius: 7px;">
              <span class="pulse" style="margin-left: 4px;"></span>
              <span style="font-size: 14px; color: var(--ink); font-weight: 500;">Copywriting pass</span>
              <span class="small" style="margin-left: auto;">ChatGPT · running</span>
            </li>
            <li style="display: flex; gap: 12px; align-items: center; padding: 10px 12px;">
              <span style="width: 16px; height: 16px; border: 1.5px solid var(--line); border-radius: 999px; flex-shrink: 0;"></span>
              <span style="font-size: 14px; color: var(--ink-soft);">Your review — mockups + copy</span>
              <span class="small" style="margin-left: auto; color: var(--green); font-weight: 500;">Checkpoint</span>
            </li>
            <li style="display: flex; gap: 12px; align-items: center; padding: 10px 12px;">
              <span style="width: 16px; height: 16px; border: 1.5px solid var(--line); border-radius: 999px; flex-shrink: 0;"></span>
              <span style="font-size: 14px; color: var(--ink-soft);">Ship to staging</span>
            </li>
          </ol>
        </Card>
      </Pillar>
    </div>
  </section>

  <!-- Pillar 03 — Memory -->
  <section class="section">
    <div class="wrap">
      <Pillar>
        <Fragment slot="copy">
          <span class="eyebrow eyebrow-green">Memory</span>
          <h2 class="section-title">Information captured as you go.</h2>
          <p class="lede">Your AI keeps your team's knowledge current as new information surfaces.</p>
          <p class="copy">
            Every conversation leaves something worth keeping. Every teammate's AI writes it down, connects it to what's already there, and updates it as things change, all on one shared brain.
          </p>
        </Fragment>
        <Card flush ariaHidden>
          <div style="padding: 16px 24px; border-bottom: 1px solid var(--line); display: flex; align-items: center; gap: 10px;">
            <span class="small" style="letter-spacing: 0.6px; text-transform: uppercase; font-weight: 500;">
              Shared brain · this week
            </span>
            <span style="flex: 1;"></span>
            <span class="small">12 items</span>
          </div>
          <div style="padding: 4px 24px 16px;">
            {captureRows.map((row, i) => (
              <div
                style={`display: grid; grid-template-columns: 32px 1fr auto; gap: 14px; padding: 14px 0; align-items: center;${
                  i ? ' border-top: 1px solid var(--line-soft);' : ''
                }`}
              >
                <span class="small" style="font-variant-numeric: tabular-nums; font-weight: 500;">{row.n}</span>
                <div>
                  <div style="font-size: 15px; color: var(--ink); font-weight: 500;">{row.t}</div>
                  <div class="small" style="margin-top: 2px;">{row.m}</div>
                </div>
                {row.done ? (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="var(--green)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 8.5l3.5 3.5L13 4.5" />
                  </svg>
                ) : (
                  <span class="pulse"></span>
                )}
              </div>
            ))}
          </div>
        </Card>
      </Pillar>
    </div>
  </section>

  <!-- Section 06 — Quick Start teaser -->
  <section class="section">
    <div class="wrap">
      <Pillar reverse>
        <Fragment slot="copy">
          <span class="eyebrow">Quick Start</span>
          <h2 class="section-title">Set up in minutes.</h2>
          <p class="lede">
            Four short steps. No credit card to start. One month of Pro included.
          </p>
          <a href="/getting-started" class="quickstart-link">See the full setup guide →</a>
        </Fragment>
        <Card flush ariaHidden={false}>
          <ol class="quickstart-steps">
            <li>
              <span class="step-num">01</span>
              <div class="step-body">
                <span class="step-lead">Sign up.</span> Free, no credit card.
                <a href="#" class="btn btn-primary step-cta">Start free →</a>
              </div>
            </li>
            <li>
              <span class="step-num">02</span>
              <div class="step-body">
                Follow the onboarding to connect your AI and set up your workspace.
              </div>
            </li>
            <li>
              <span class="step-num">03</span>
              <div class="step-body">
                In your AI, say <code>use octopad</code> and tell it about your company and what you are building. Your AI will capture that information and load it at each session.
              </div>
            </li>
            <li>
              <span class="step-num">04</span>
              <div class="step-body">
                Your AI's back-office is now ready for work.
              </div>
            </li>
          </ol>
        </Card>
      </Pillar>
    </div>
  </section>

  <!-- Section 07 — FAQ (accordion + FAQPage JSON-LD via head slot) -->
  <FAQ />

  <CTABand
    heading="Give your AI the back-office it's been missing."
    description="Free to start. One month of Pro included. Works with any MCP-compatible model. Pro from $9 per seat when you're ready for more."
  >
    <a href="#" class="btn btn-primary btn-lg">Start free</a>
    <a href="/pricing" class="btn btn-ghost">See pricing</a>
  </CTABand>
</BaseLayout>
