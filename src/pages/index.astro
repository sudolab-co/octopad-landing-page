---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Pillar from '../components/Pillar.astro';
import PillarContextChat from '../components/PillarContextChat.astro';
import PillarPlansChat from '../components/PillarPlansChat.astro';
import PillarMemoryChat from '../components/PillarMemoryChat.astro';
import Card from '../components/Card.astro';
import Tile from '../components/Tile.astro';
import CTABand from '../components/CTABand.astro';
import FAQ from '../components/FAQ.astro';
import { buildFAQSchema } from '../data/faq';

const faqSchema = buildFAQSchema();
---

<BaseLayout
  title="Octopad — Your AI's back-office"
  description="A shared workspace where any AI your team uses — Claude, ChatGPT, Cursor — can make plans, run tasks, and capture what matters on one shared brain."
  page="product"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <Hero
    heading="Your AI's<br/>back-office"
    lede="Make plans, run tasks, and capture what matters, all in your AI."
    primaryCta={{ label: 'Start free', href: 'https://www.octopad.app/signup' }}
    secondaryCta={{ label: 'See how it works', href: '#' }}
    trustLine="Free to start. First month of Pro included. $9 per seat after."
  />

  <hr class="rule" />

  <!-- Social proof strip -->
  <section class="wrap">
    <div class="trust">
      <span class="eyebrow label">Works with Claude, ChatGPT, Cursor, and any MCP-compatible AI.</span>
      <div class="logos">
        <b>Claude</b><span class="dot"></span>
        <b>ChatGPT</b><span class="dot"></span>
        <b>Cursor</b><span class="dot"></span>
        <span class="mcp-pill">+ any MCP-compatible AI</span>
      </div>
    </div>
  </section>

  <!-- Pillar 01 — Context -->
  <section class="section">
    <div class="wrap">
      <Pillar>
        <Fragment slot="copy">
          <span class="eyebrow pillar-num">01</span>
          <h2 class="section-title">The right context for every task</h2>
          <p class="lede">Your AI knows what each task needs, without any prompt. It pulls from the information in your workspace, picks what matters, and builds the right mix for every job before you even ask.</p>
        </Fragment>
        <PillarContextChat />
      </Pillar>
    </div>
  </section>

  <!-- Pillar 02 — Plans -->
  <section class="section">
    <div class="wrap">
      <Pillar reverse>
        <Fragment slot="copy">
          <span class="eyebrow pillar-num">02</span>
          <h2 class="section-title">Plans ready for execution</h2>
          <p class="lede">Your AI generates detail-rich tasks and maintains execution coherence from start to finish. It writes every task the same way, ties it to your strategy, and keeps the work moving across sessions, on its own.</p>
        </Fragment>
        <PillarPlansChat />
      </Pillar>
    </div>
  </section>

  <!-- Pillar 03 — Memory -->
  <section class="section">
    <div class="wrap">
      <Pillar>
        <Fragment slot="copy">
          <span class="eyebrow pillar-num">03</span>
          <h2 class="section-title">Captured as you go</h2>
          <p class="lede">Your AI keeps your team's knowledge current as new information surfaces. It writes down what's worth keeping from every conversation, connects it to what's already there, and updates it as things change, all in your workspace.</p>
        </Fragment>
        <PillarMemoryChat />
      </Pillar>
    </div>
  </section>

  <!-- Section 06 — Quick Start teaser -->
  <section class="section">
    <div class="wrap">
      <Pillar reverse>
        <Fragment slot="copy">
          <span class="eyebrow">Quick Start</span>
          <h2 class="section-title">Set up in minutes</h2>
          <p class="lede">
            Four short steps. No credit card to start. One month of Pro included.
          </p>
          <a href="/getting-started" class="quickstart-link">See the full setup guide →</a>
        </Fragment>
        <Card flush ariaHidden={false}>
          <ol class="quickstart-steps">
            <li>
              <span class="step-num">01</span>
              <div class="step-body">
                <span class="step-lead">Sign up.</span> Free, no credit card.
                <a href="https://www.octopad.app/signup" class="btn btn-primary step-cta">Start free →</a>
              </div>
            </li>
            <li>
              <span class="step-num">02</span>
              <div class="step-body">
                Follow the onboarding to connect your AI and set up your workspace.
              </div>
            </li>
            <li>
              <span class="step-num">03</span>
              <div class="step-body">
                In your AI, say <code>use octopad</code> and tell it about your company and what you are building. Your AI will capture that information and load it at each session.
              </div>
            </li>
            <li>
              <span class="step-num">04</span>
              <div class="step-body">
                Your AI's back-office is now ready for work.
              </div>
            </li>
          </ol>
        </Card>
      </Pillar>
    </div>
  </section>

  <!-- Section 07 — FAQ (accordion + FAQPage JSON-LD via head slot) -->
  <FAQ />

  <CTABand
    heading="Give your AI the back-office it's been missing"
    description="Free to start. One month of Pro included. Works with any MCP-compatible model. Pro from $9 per seat when you're ready for more."
  >
    <a href="https://www.octopad.app/signup" class="btn btn-primary btn-lg">Start free</a>
    <a href="/pricing" class="btn btn-ghost">See pricing</a>
  </CTABand>
</BaseLayout>
