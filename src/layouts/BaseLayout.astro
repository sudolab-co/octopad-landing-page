---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  page?: 'product' | 'pricing' | 'quickstart' | 'about' | 'blog';
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description,
  page,
  ogImage,
  ogType = 'website',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://octopad.ai';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImage = new URL(ogImage ?? '/og-image.png', siteUrl).toString();

const defaultDescription =
  "Octopad is your AI's back-office: a shared workspace where any AI your team uses (Claude, ChatGPT, Cursor) can make plans, run tasks, and capture what matters, all in your AI.";
const metaDescription = description ?? defaultDescription;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Octopad',
  url: siteUrl,
  logo: `${siteUrl}/assets/mascot.svg`,
  description:
    "Octopad is the AI back-office: a shared workspace where any AI your team uses can plan, run tasks, and capture what matters, all in your AI.",
  sameAs: ['https://x.com/octopad_ai'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Octopad',
  url: siteUrl,
  description: defaultDescription,
  publisher: { '@type': 'Organization', name: 'Octopad' },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/assets/mascot.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#2a9f73" />

    <meta property="og:site_name" content="Octopad" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Octopad — your AI's back-office" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@octopad_ai" />
    <meta name="twitter:creator" content="@octopad_ai" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={socialImage} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;450;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <Nav page={page} />
    <main>
      <slot />
    </main>
    <Footer />
    {import.meta.env.DEV && <script is:inline src="/scripts/tweaks.js"></script>}
  </body>
</html>
